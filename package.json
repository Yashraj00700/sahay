{
  "name": "sahay",
  "version": "0.1.0",
  "private": true,
  "description": "Sahay — AI Customer Support Platform for Indian D2C Brands",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate --filter=@sahay/db",
    "db:migrate": "turbo run db:migrate --filter=@sahay/db",
    "db:push": "turbo run db:push --filter=@sahay/db",
    "db:studio": "turbo run db:studio --filter=@sahay/db",
    "db:seed": "turbo run db:seed --filter=@sahay/db",
    "infra:up": "docker-compose -f infrastructure/docker-compose.yml up -d",
    "infra:down": "docker-compose -f infrastructure/docker-compose.yml down",
    "infra:logs": "docker-compose -f infrastructure/docker-compose.yml logs -f",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "secrets:check": "bash scripts/check-secrets.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@sentry/node": "^8.45.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "@vercel/node": "^5.1.0",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "inngest": "^3.27.0",
    "openai": "^4.91.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.7",
    "pusher": "^5.2.0",
    "resend": "^4.5.2",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "prettier": "^3.5.3",
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@types/node": "^22.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/web-push": "^3.6.4",
    "typescript": "^5.7.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
