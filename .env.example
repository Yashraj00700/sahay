# ─── DATABASE ─────────────────────────────────────────────
DATABASE_URL=postgresql://sahay:sahaydev123@localhost:5432/sahay_dev
# DATABASE_URL_PROD=postgresql://...@rds.amazonaws.com/sahay

# ─── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── UPSTASH (serverless Redis for Vercel Functions) ──────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ─── JWT AUTH ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-32-char-random-string-minimum
JWT_REFRESH_SECRET=change-me-to-another-32-char-random-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ─── ENCRYPTION ───────────────────────────────────────────
# 32+ char key for AES-256 column encryption (OAuth tokens, PII).
# Generate with: openssl rand -base64 48
ENCRYPTION_KEY=change-me-to-a-32-char-random-string-minimum

# ─── SHOPIFY ──────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
# Same value as SHOPIFY_API_SECRET unless you've rotated webhooks separately.
SHOPIFY_WEBHOOK_SECRET=your_shopify_api_secret_here
SHOPIFY_APP_URL=http://localhost:3002
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,write_customers,read_products,write_products,read_fulfillments,read_inventory,write_draft_orders

# ─── WHATSAPP CLOUD API (Meta) ────────────────────────────
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_permanent_access_token
WA_VERIFY_TOKEN=your_random_verify_token_string
WA_APP_SECRET=your_meta_app_secret_for_hmac

# ─── INSTAGRAM (Meta) ─────────────────────────────────────
IG_APP_ID=your_meta_app_id
IG_APP_SECRET=your_meta_app_secret
IG_VERIFY_TOKEN=your_instagram_verify_token

# ─── AI PROVIDERS ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_API_KEY=sk-your-openai-api-key

# ─── STORAGE (Cloudflare R2 or AWS S3) ────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=sahay-media-dev
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ─── EMAIL (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@sahay.ai

# ─── PUSHER (realtime websockets) ─────────────────────────
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=ap2

# ─── INNGEST (background jobs) ────────────────────────────
# Optional in local dev — Inngest dev server runs without keys.
# Required in production / preview deployments.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── MONITORING ───────────────────────────────────────────
SENTRY_DSN=https://your_key@o0.ingest.sentry.io/0
# Build-time only: used by @sentry/cli to upload sourcemaps. Never read at runtime.
SENTRY_AUTH_TOKEN=

# ─── APP URLs ─────────────────────────────────────────────
NODE_ENV=development
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
SHOPIFY_APP_HOST=localhost:3002

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ─── WEB / VITE PUBLIC ────────────────────────────────────
# These are bundled into the browser build by Vite — only put
# values here that are safe to expose publicly. They must be
# prefixed with VITE_ to be picked up by import.meta.env.
VITE_SENTRY_DSN=
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=ap2
VITE_API_URL=http://localhost:3001
